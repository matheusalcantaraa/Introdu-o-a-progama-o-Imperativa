#include <stdio.h>

void aplicar_enfeites(char matriz[][100], int m, int n){
    for(int i = 0; i < m; i++){
        for(int j = 0; j < n; j++){
            if(matriz[i][j] == 'P'){
                if(i-1 >= 0 && (matriz[i-1][j] == '-' || matriz[i-1][j] == 'x')) matriz[i-1][j] = '+';
                if(i+1 < m && (matriz[i+1][j] == '-' || matriz[i+1][j] == 'x')) matriz[i+1][j] = '+';
                if(j-1 >= 0 && (matriz[i][j-1] == '-' || matriz[i][j-1] == 'x')) matriz[i][j-1] = '+';
                if(j+1 < n && (matriz[i][j+1] == '-' || matriz[i][j+1] == 'x')) matriz[i][j+1] = '+';
                if(i-1 >= 0 && j-1 >= 0 && matriz[i-1][j-1] == '-') matriz[i-1][j-1] = 'x';
                if(i-1 >= 0 && j+1 < n && matriz[i-1][j+1] == '-') matriz[i-1][j+1] = 'x';
                if(i+1 < m && j-1 >= 0 && matriz[i+1][j-1] == '-') matriz[i+1][j-1] = 'x';
                if(i+1 < m && j+1 < n && matriz[i+1][j+1] == '-') matriz[i+1][j+1] = 'x';
            }
        }
    }
}

int main(){
    int m, n;
    scanf("%d %d", &m, &n);
    char matriz[m][100];
    for(int i = 0; i < m; i++){
        scanf(" ");
        for(int j = 0; j < n; j++){
            scanf("%c", &matriz[i][j]);
        }
    }
    aplicar_enfeites(matriz, m, n);
    for(int i = 0; i < m; i++){
        for(int j = 0; j < n; j++){
            printf("%c", matriz[i][j]);
        }
        printf("\n");
    }
}
