#include <stdio.h>
#include <stdlib.h>

int calibracao(int valor) {
    return valor + 5;
}

int saturacao(int valor) {
    if (valor > 80) {
        return 80;
    } else {
        return valor;
    }
}

int amplificador(int valor) {
    return valor * 2;
}

void modificar(int **matriz, int linhas, int colunas, int (**pipeline)(int), int tamanho) {
    int i, j, f;
    for (i = 0; i < linhas; i++) {
        for (j = 0; j < colunas; j++) {
            for (f = 0; f < tamanho; f++) {
                matriz[i][j] = pipeline[f](matriz[i][j]);
            }
        }
    }
}

int main() {
    int n, m;
    scanf("%d %d", &n, &m);

    int **matriz = malloc(n * sizeof(int *));
    int i, j;
    for (i = 0; i < n; i++) {
        matriz[i] = malloc(m * sizeof(int));
    }

    for (i = 0; i < n; i++) {
        for (j = 0; j < m; j++) {
            scanf("%d", &matriz[i][j]);
        }
    }

    int (*filtros[3])(int) = {calibracao, saturacao, amplificador};

    int comando;
    while (scanf("%d", &comando) == 1 && comando != 0) {
        if (comando == 1 || comando == 2 || comando == 3) {
            int (*pipeline[1])(int);
            pipeline[0] = filtros[comando - 1];
            modificar(matriz, n, m, pipeline, 1);
        } else if (comando == 4) {
            int k;
            scanf("%d", &k);
            int (**pipeline)(int) = malloc(k * sizeof(int (*)(int)));
            int f;
            for (f = 0; f < k; f++) {
                int id;
                scanf("%d", &id);
                pipeline[f] = filtros[id - 1];
            }
            modificar(matriz, n, m, pipeline, k);
            free(pipeline);
        }
    }

    printf("Matriz processada:\n");
    for (i = 0; i < n; i++) {
        for (j = 0; j < m; j++) {
            if (j > 0) {
                printf(" ");
            }
            printf("%d", matriz[i][j]);
        }
        printf("\n");
    }

    int maior = matriz[0][0];
    int linha_max = 0, col_max = 0;
    for (i = 0; i < n; i++) {
        for (j = 0; j < m; j++) {
            if (matriz[i][j] > maior) {
                maior = matriz[i][j];
                linha_max = i;
                col_max = j;
            }
        }
    }

    printf("\nSensor critico: %d\n", maior);
    printf("Posicao: (%d,%d)\n", linha_max, col_max);

    for (i = 0; i < n; i++) {
        free(matriz[i]);
    }
    free(matriz);

    return 0;
}
