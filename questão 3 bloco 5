#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char* ler_string() {
    char *string = malloc(sizeof(char));
    if (!string) { printf("Erro de alocacao\n"); exit(1); }

    int tamanho = 0;
    char caractere_lido;
    while ((caractere_lido = getchar()) != '\n' && caractere_lido != EOF) {
        char *temp = realloc(string, (tamanho + 2) * sizeof(char));
        if (!temp) { printf("Erro de alocacao\n"); free(string); exit(1); }
        string = temp;
        string[tamanho++] = caractere_lido;
    }
    string[tamanho] = '\0';
    return string;
}

char* mesclar(char **strings, int quantidade_strings) {
    int tamanho_total = 0;
    for (int i = 0; i < quantidade_strings; i++)
        tamanho_total += strlen(strings[i]);

    char *resultado = malloc((tamanho_total + 1) * sizeof(char));
    if (!resultado) { printf("Erro de alocacao\n"); exit(1); }

    int posicao_mesclada = 0;
    int posicao_atual = 0;
    int ainda_tem_caractere = 1;

    while (ainda_tem_caractere) {
        ainda_tem_caractere = 0;
        for (int i = 0; i < quantidade_strings; i++) {
            if (posicao_atual < (int)strlen(strings[i])) {
                resultado[posicao_mesclada++] = strings[i][posicao_atual];
                ainda_tem_caractere = 1;
            }
        }
        posicao_atual++;
    }

    resultado[posicao_mesclada] = '\0';
    return resultado;
}

char* fundir(char *string_mesclada) {
    char *resultado = malloc((strlen(string_mesclada) + 1) * sizeof(char));
    if (!resultado) { printf("Erro de alocacao\n"); exit(1); }
    strcpy(resultado, string_mesclada);

    int posicao_atual = 0;
    while (posicao_atual < (int)strlen(resultado) - 1) {
        if (resultado[posicao_atual] == resultado[posicao_atual + 1]) {
            resultado[posicao_atual] = (resultado[posicao_atual] == 'z') ? 'a' : resultado[posicao_atual] + 1;
            int tamanho_atual = strlen(resultado);
            for (int j = posicao_atual + 1; j < tamanho_atual; j++)
                resultado[j] = resultado[j + 1];
            resultado[tamanho_atual - 1] = '\0';
            if (posicao_atual > 0) posicao_atual--;
        } else {
            posicao_atual++;
        }
    }

    return resultado;
}

int main() {
    int quantidade_strings;
    scanf("%d", &quantidade_strings);
    getchar();

    char **strings = malloc(quantidade_strings * sizeof(char*));
    if (!strings) { printf("Erro de alocacao\n"); return 1; }

    for (int i = 0; i < quantidade_strings; i++)
        strings[i] = ler_string();

    char *string_mesclada = mesclar(strings, quantidade_strings);
    char *string_fundida = fundir(string_mesclada);

    printf("%s\n%s\n", string_mesclada, string_fundida);

    for (int i = 0; i < quantidade_strings; i++) free(strings[i]);
    free(strings);
    free(string_mesclada);
    free(string_fundida);

    return 0;
}


