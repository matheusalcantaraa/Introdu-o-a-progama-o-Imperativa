#include <stdio.h>

int main(){

    char C;
    scanf("%c", &C);

    int largura = 2*(C - 'A') + 1;

    for(char i = 'A'; i <= C; i++){

        int letras = 2*(i - 'A') + 1;
        int pontos = (largura - letras)/2;

        for(int k = 0; k < pontos; k++){
            printf(".");
        }

        for(char j = 'A'; j <= i; j++){
            printf("%c", j);
        }

        for(char j = i-1; j >= 'A'; j--){
            printf("%c", j);
        }

        for(int k = 0; k < pontos; k++){
            printf(".");
        }

        printf("\n");
    }

}
